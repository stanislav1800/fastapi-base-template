# ────────────── ENVIRONMENT CONFIGURATION ──────────────
PROJECT_NAME=YOUR_PROJECT_NAME
LOG_LEVEL=INFO

# ────────────── JWT / Auth ──────────────
SECRET_KEY=YOUR_SECRET_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_SECONDS=900
REFRESH_TOKEN_EXPIRE_SECONDS=2592000
ACCESS_TOKEN_TRANSPORT=header
REFRESH_TOKEN_TRANSPORT=cookie

# ────────────── DATABASE CONFIGURATION ──────────────
DB_NAME=fastapi_base_template
DB_USER=postgres
DB_PASSWORD=SomeSecretPassword12!
DB_HOST=fastapi_db
DB_PORT=5432
POSTGRES_DB_URL=postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# ────────────── REDIS  ──────────────
REDIS_HOST=fastapi_redis
REDIS_PORT=6379

REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}
